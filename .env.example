# ============================================
# 沉鱼AI畅聊助手 - 环境变量配置说明
# 部署到 Zeabur / Render / 任何平台时需要设置
# ============================================

# --- 核心服务 ---
# 服务端口（Zeabur自动注入，一般无需手动设）
PORT=5678

# --- AI引擎（智谱GLM-4）---
# ⚠️ 必填！从 https://open.bigmodel.cn 获取API Key
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4

# --- 认证加密 ---
# JWT签名密钥（用于用户Token签发验证）
JWT_SECRET=your_random_jwt_secret_here
# Flask Session加密密钥
SECRET_KEY=your_random_secret_key_here

# --- 数据库 ---
# SQLite数据库路径（Zeabur建议设为持久化目录）
DB_PATH=/app/data/app.db
